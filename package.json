{
  "name": "spotplay",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@spotplay/db",
    "db:push": "turbo run db:push --filter=@spotplay/db",
    "db:migrate": "turbo run db:migrate --filter=@spotplay/db",
    "db:studio": "turbo run db:studio --filter=@spotplay/db",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@prisma/client": "^6.2.0",
    "@types/node": "^22.15.3",
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}